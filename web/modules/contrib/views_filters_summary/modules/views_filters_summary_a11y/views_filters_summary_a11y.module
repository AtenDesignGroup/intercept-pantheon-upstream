<?php

/**
 * @file
 * Hook implementations for views_filters_summary_a11y module.
 */

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\views_filters_summary_a11y\Hook\ViewsFiltersSummaryA11yHooks;

/**
 * Implements hook_theme().
 */
#[LegacyHook]
function views_filters_summary_a11y_theme($existing, $type, $theme, $path): array {
  return \Drupal::service(ViewsFiltersSummaryA11yHooks::class)->theme($existing, $type, $theme, $path);
}

/**
 * Implements hook_library_info_alter().
 */
#[LegacyHook]
function views_filters_summary_a11y_library_info_alter(&$libraries, $extension) {
  \Drupal::service(ViewsFiltersSummaryA11yHooks::class)->libraryInfoAlter($libraries, $extension);
}

/**
 * Implements hook_views_filters_summary_item_alter().
 */
#[LegacyHook]
function views_filters_summary_a11y_views_filters_summary_item_alter(&$item) {
  \Drupal::service(ViewsFiltersSummaryA11yHooks::class)->itemAlter($item);
}
