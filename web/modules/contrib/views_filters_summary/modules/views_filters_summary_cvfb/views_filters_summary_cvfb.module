<?php

/**
 * @file
 * Hook implementations for views_filters_summary_cvfb module.
 */

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\views_filters_summary_cvfb\Hook\ViewsFiltersSummaryCvfbHooks;

/**
 * Implements hook_library_info_alter().
 */
#[LegacyHook]
function views_filters_summary_cvfb_library_info_alter(&$libraries, $extension) {
  \Drupal::service(ViewsFiltersSummaryCvfbHooks::class)->libraryInfoAlter($libraries, $extension);
}
