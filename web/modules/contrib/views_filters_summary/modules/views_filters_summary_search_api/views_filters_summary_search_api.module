<?php

/**
 * @file
 * Hook implementations for views_filters_summary_search_api module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\views_filters_summary_search_api\Hook\ViewsFiltersSummarySearchApiHooks;

/**
 * Implements hook_views_filters_summary_plugin_alias().
 */
#[LegacyHook]
function views_filters_summary_search_api_views_filters_summary_plugin_alias($filter) {
  return \Drupal::service(ViewsFiltersSummarySearchApiHooks::class)->pluginAlias($filter);
}

/**
 * Implements hook_views_filters_summary_replacements_alter().
 */
#[LegacyHook]
function views_filters_summary_search_api_views_filters_summary_replacements_alter(&$replacements, $view) {
  \Drupal::service(ViewsFiltersSummarySearchApiHooks::class)->replacementsAlter($replacements, $view);
}

/**
 * Implements hook_form_alter().
 */
#[LegacyHook]
function views_filters_summary_search_api_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  \Drupal::service(ViewsFiltersSummarySearchApiHooks::class)->formAlter($form, $form_state, $form_id);
}

/**
 * Implements hook_views_filters_summary_valid_index().
 */
#[LegacyHook]
function views_filters_summary_search_api_views_filters_summary_valid_index($index, $filter) {
  return \Drupal::service(ViewsFiltersSummarySearchApiHooks::class)->validIndex($index, $filter);
}
