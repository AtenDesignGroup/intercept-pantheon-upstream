{#
  Themes the filter items in the Views Filters Summary block.

  Available variables:
  - summary: The filter items.
  - options: The filter related summary options.
#}
<span class="items">
  {%- for item in summary -%}
    <span class="item">
      {% if options.show_label %}
        <span class="label">{{ item.label }}:</span>
      {% endif %}

      {% if options.has_group_values %}
        <span class="values">
          {%- for value in item.groups -%}
            {% include 'views-filters-summary-item.html.twig' with {
              item: value,
              options: options
            } %}
          {% endfor %}
         </span>
      {% else %}
        {% include 'views-filters-summary-item.html.twig' with {
          item: item,
          options: options
        } %}
      {% endif %}

      {% if loop.last == false %}
        {{- options.filters_summary.separator -}}
      {% endif %}
    </span>
  {%- endfor -%}
</span>
